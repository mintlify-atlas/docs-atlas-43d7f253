  "keyFeatures": [
    "Automated WhatsApp message scheduling with configurable delays",
    "Redis-powered job queue with BullMQ for reliable message delivery",
    "RESTful API for managing contacts and scheduled messages",
    "WhatsApp Web.js integration with QR code authentication",
    "SQLite database with Prisma ORM for data persistence",
    "Basic authentication for API endpoints"
  ],
  "publicApiSurface": [
    "GET /messages/all - List all scheduled messages",
    "POST /messages/create-one - Create a new scheduled message",
    "GET /messages/read-one/:id - Get a specific message",
    "POST /messages/update-one/:id - Update a scheduled message",
    "POST /messages/delete-one/:id - Delete a scheduled message",
    "POST /messages/send-instant - Send an immediate WhatsApp message",
    "GET /messages/reschedule - Manually trigger message rescheduling",
    "GET /people/all - List all contacts",
    "POST /people/create-one - Add a new contact",
    "GET /people/read-one/:id - Get a specific contact",
    "POST /people/update-one/:id - Update a contact",
    "POST /people/delete-one/:id - Delete a contact",
    "GET / - Health check endpoint",
    "GET /time-left - Get time remaining until next scheduled message"
  ]
}
